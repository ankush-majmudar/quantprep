{
  "version": 1,
  "note": "Technique taxonomy + prerequisite DAG. 'family' groups techniques for the mastery radar; 'prereqs' (technique ids) drives the skill-tree roadmap. 'tier' is a coarse ordering 1=fundamentals .. 5=advanced.",
  "families": [
    { "id": "counting",     "name": "Counting & Combinatorics",   "color": "#4F8DFD" },
    { "id": "prob",         "name": "Probability Foundations",    "color": "#22B8A6" },
    { "id": "expectation",  "name": "Expectation",                "color": "#7C5CFC" },
    { "id": "dists",        "name": "Distributions",              "color": "#F2A93B" },
    { "id": "states",       "name": "States & Recursion",         "color": "#E5639B" },
    { "id": "contrv",       "name": "Continuous Random Variables","color": "#3FBF6F" },
    { "id": "varcov",       "name": "Variance & Covariance",      "color": "#FF7A59" },
    { "id": "stoch",        "name": "Martingales & Stochastic",   "color": "#9B6CF0" },
    { "id": "stats",        "name": "Statistics & Regression",    "color": "#19A0C4" },
    { "id": "finance",      "name": "Finance & Arbitrage",        "color": "#C6A100" },
    { "id": "teasers",      "name": "Brainteaser Tactics",        "color": "#6E7BFF" },
    { "id": "mentalmath",   "name": "Mental Math & Estimation",   "color": "#2DC2A0" },
    { "id": "games",        "name": "Game Theory & Market Making","color": "#FF5C8A" },
    { "id": "puremath",     "name": "Pure Math & Algebra",        "color": "#8B9BB4" }
  ],
  "techniques": [
    { "id": "arithmetic_speed",   "family": "mentalmath",  "tier": 1, "name": "Fast arithmetic",                 "desc": "Rapid +,-,×,÷ on integers, fractions, decimals under time pressure.", "prereqs": [] },
    { "id": "fractions_decimals", "family": "mentalmath",  "tier": 1, "name": "Fractions ↔ decimals ↔ %",         "desc": "Fluent conversion and manipulation of fractions, decimals, percentages.", "prereqs": ["arithmetic_speed"] },
    { "id": "approximation",      "family": "mentalmath",  "tier": 2, "name": "Approximation & Fermi estimation","desc": "Order-of-magnitude estimates, sanity-checking, back-of-envelope.", "prereqs": ["fractions_decimals"] },

    { "id": "basic_counting",     "family": "counting",    "tier": 1, "name": "Multiplication & addition rules",  "desc": "Product/sum rules, ordered vs unordered selection.", "prereqs": [] },
    { "id": "permutations",       "family": "counting",    "tier": 1, "name": "Permutations & arrangements",      "desc": "nPk, arrangements with restrictions, circular permutations.", "prereqs": ["basic_counting"] },
    { "id": "combinations",       "family": "counting",    "tier": 1, "name": "Combinations (n choose k)",        "desc": "Binomial coefficients, choosing subsets.", "prereqs": ["basic_counting"] },
    { "id": "stars_and_bars",     "family": "counting",    "tier": 2, "name": "Stars and bars",                   "desc": "Counting integer solutions / distributing identical items.", "prereqs": ["combinations"] },
    { "id": "complementary_count","family": "counting",    "tier": 2, "name": "Complementary counting",           "desc": "Count the complement when direct counting is hard.", "prereqs": ["combinations"] },
    { "id": "inclusion_exclusion","family": "counting",    "tier": 3, "name": "Inclusion–exclusion",              "desc": "Correcting for overcounting across overlapping sets.", "prereqs": ["complementary_count"] },
    { "id": "bijections",         "family": "counting",    "tier": 3, "name": "Bijections & overcounting",        "desc": "Map a hard count to an equivalent easier one.", "prereqs": ["combinations"] },
    { "id": "pigeonhole",         "family": "counting",    "tier": 2, "name": "Pigeonhole principle",             "desc": "Existence arguments from counting.", "prereqs": ["basic_counting"] },

    { "id": "sample_space",       "family": "prob",        "tier": 1, "name": "Sample spaces & equally likely",   "desc": "Define outcomes, count favorable/total.", "prereqs": ["basic_counting"] },
    { "id": "symmetry_prob",      "family": "prob",        "tier": 2, "name": "Symmetry arguments",               "desc": "Exploit symmetry to avoid computation.", "prereqs": ["sample_space"] },
    { "id": "conditional_prob",   "family": "prob",        "tier": 2, "name": "Conditional probability",          "desc": "P(A|B), multiplication rule, tree diagrams.", "prereqs": ["sample_space"] },
    { "id": "independence",       "family": "prob",        "tier": 2, "name": "Independence",                      "desc": "Independent events, joint probabilities.", "prereqs": ["sample_space"] },
    { "id": "total_probability",  "family": "prob",        "tier": 2, "name": "Law of total probability",         "desc": "Condition on a partition to combine cases.", "prereqs": ["conditional_prob"] },
    { "id": "bayes",              "family": "prob",        "tier": 3, "name": "Bayes' theorem",                   "desc": "Invert conditionals, posterior reasoning.", "prereqs": ["total_probability"] },
    { "id": "inclusion_excl_prob","family": "prob",        "tier": 3, "name": "Union/intersection probabilities", "desc": "P(A∪B), inclusion–exclusion for probabilities.", "prereqs": ["independence"] },

    { "id": "linearity_exp",      "family": "expectation", "tier": 2, "name": "Linearity of expectation",         "desc": "E[X+Y]=E[X]+E[Y] even with dependence.", "prereqs": ["sample_space"] },
    { "id": "indicator_vars",     "family": "expectation", "tier": 2, "name": "Indicator variables",              "desc": "Sum indicators to compute expected counts.", "prereqs": ["linearity_exp"] },
    { "id": "tail_sum",           "family": "expectation", "tier": 3, "name": "Tail-sum / survival formula",      "desc": "E[X]=Σ P(X≥k) for nonneg integer X.", "prereqs": ["linearity_exp"] },
    { "id": "law_total_exp",      "family": "expectation", "tier": 3, "name": "Law of total expectation",         "desc": "E[X]=E[E[X|Y]], condition to compute.", "prereqs": ["linearity_exp", "conditional_prob"] },
    { "id": "cond_expectation",   "family": "expectation", "tier": 3, "name": "Conditional expectation",          "desc": "E[X|Y], setting up recursive expectations.", "prereqs": ["law_total_exp"] },

    { "id": "binomial",           "family": "dists",       "tier": 2, "name": "Binomial distribution",            "desc": "Counts of successes in n Bernoulli trials.", "prereqs": ["independence", "combinations"] },
    { "id": "geometric",          "family": "dists",       "tier": 2, "name": "Geometric / waiting time",         "desc": "Trials until first success; memorylessness.", "prereqs": ["independence"] },
    { "id": "poisson",            "family": "dists",       "tier": 3, "name": "Poisson distribution",             "desc": "Rare-event counts, Poisson approximation.", "prereqs": ["binomial"] },
    { "id": "uniform_discrete",   "family": "dists",       "tier": 1, "name": "Discrete uniform",                 "desc": "Equally likely discrete values (dice, cards).", "prereqs": ["sample_space"] },
    { "id": "negbinom",           "family": "dists",       "tier": 3, "name": "Negative binomial",                "desc": "Trials until r-th success.", "prereqs": ["geometric"] },

    { "id": "first_step",         "family": "states",      "tier": 3, "name": "First-step analysis",              "desc": "Set up equations by conditioning on the first move.", "prereqs": ["cond_expectation"] },
    { "id": "markov_chain",       "family": "states",      "tier": 4, "name": "Markov chains",                    "desc": "State transitions, stationary distributions.", "prereqs": ["first_step"] },
    { "id": "gamblers_ruin",      "family": "states",      "tier": 4, "name": "Gambler's ruin",                   "desc": "Absorption probabilities on a random walk.", "prereqs": ["first_step"] },
    { "id": "hitting_time",       "family": "states",      "tier": 4, "name": "Expected hitting time",            "desc": "Expected steps to reach a state.", "prereqs": ["first_step"] },
    { "id": "recursion",          "family": "states",      "tier": 3, "name": "Recursion / states setup",         "desc": "Define states and recurrences for a process.", "prereqs": ["cond_expectation"] },

    { "id": "pdf_cdf",            "family": "contrv",      "tier": 3, "name": "Densities & CDFs",                 "desc": "Work with f(x), F(x), compute probabilities by integration.", "prereqs": ["sample_space"] },
    { "id": "uniform_cont",       "family": "contrv",      "tier": 3, "name": "Continuous uniform & geometry",    "desc": "Uniform on an interval/region; geometric probability.", "prereqs": ["pdf_cdf"] },
    { "id": "exponential",        "family": "contrv",      "tier": 3, "name": "Exponential distribution",         "desc": "Memoryless continuous waiting time.", "prereqs": ["pdf_cdf"] },
    { "id": "normal",             "family": "contrv",      "tier": 3, "name": "Normal distribution",              "desc": "Gaussian, standardization, 68-95-99.7.", "prereqs": ["pdf_cdf"] },
    { "id": "order_statistics",   "family": "contrv",      "tier": 4, "name": "Order statistics",                 "desc": "Distribution of min/max/k-th of samples.", "prereqs": ["pdf_cdf"] },
    { "id": "transformations",    "family": "contrv",      "tier": 4, "name": "Transformations of RVs",           "desc": "Change of variables, derived distributions.", "prereqs": ["pdf_cdf"] },
    { "id": "joint_cont",         "family": "contrv",      "tier": 4, "name": "Joint & marginal densities",       "desc": "Multivariate densities, marginalization.", "prereqs": ["pdf_cdf"] },

    { "id": "variance_props",     "family": "varcov",      "tier": 3, "name": "Variance properties",              "desc": "Var(aX+b), Var of sums, computing variance.", "prereqs": ["linearity_exp"] },
    { "id": "covariance",         "family": "varcov",      "tier": 3, "name": "Covariance",                       "desc": "Cov(X,Y), bilinearity, variance of sums.", "prereqs": ["variance_props"] },
    { "id": "correlation",        "family": "varcov",      "tier": 3, "name": "Correlation",                      "desc": "Correlation coefficient, bounds, interpretation.", "prereqs": ["covariance"] },
    { "id": "cond_variance",      "family": "varcov",      "tier": 4, "name": "Law of total variance",            "desc": "Var(X)=E[Var(X|Y)]+Var(E[X|Y]).", "prereqs": ["covariance", "cond_expectation"] },

    { "id": "martingale",         "family": "stoch",       "tier": 5, "name": "Martingales",                      "desc": "Fair-game processes, martingale property.", "prereqs": ["cond_expectation"] },
    { "id": "optional_stopping",  "family": "stoch",       "tier": 5, "name": "Optional stopping",                "desc": "E[stopped martingale]=start under conditions.", "prereqs": ["martingale"] },
    { "id": "brownian",           "family": "stoch",       "tier": 5, "name": "Brownian motion",                  "desc": "Properties of BM, scaling, hitting.", "prereqs": ["normal", "martingale"] },
    { "id": "ito",                "family": "stoch",       "tier": 5, "name": "Itô calculus",                     "desc": "Itô's lemma, SDEs.", "prereqs": ["brownian"] },

    { "id": "estimation_stats",   "family": "stats",       "tier": 3, "name": "Estimation & MLE",                 "desc": "Estimators, bias, maximum likelihood.", "prereqs": ["variance_props"] },
    { "id": "hypothesis_test",    "family": "stats",       "tier": 4, "name": "Hypothesis testing",               "desc": "Tests, p-values, errors.", "prereqs": ["normal"] },
    { "id": "regression",         "family": "stats",       "tier": 4, "name": "Linear regression",                "desc": "OLS, coefficients, R², assumptions.", "prereqs": ["covariance"] },
    { "id": "bias_variance",      "family": "stats",       "tier": 4, "name": "Bias–variance & estimators",       "desc": "Trade-offs, MSE decomposition.", "prereqs": ["estimation_stats"] },

    { "id": "ev_betting",         "family": "finance",     "tier": 2, "name": "Expected value of bets",           "desc": "EV of wagers/games, fair price.", "prereqs": ["linearity_exp"] },
    { "id": "arbitrage",          "family": "finance",     "tier": 4, "name": "Arbitrage & no-arbitrage",         "desc": "Replication, no free lunch, pricing bounds.", "prereqs": ["ev_betting"] },
    { "id": "option_basics",      "family": "finance",     "tier": 4, "name": "Option payoffs & pricing",         "desc": "Calls/puts payoffs, put-call parity, intuition.", "prereqs": ["arbitrage"] },
    { "id": "kelly",              "family": "finance",     "tier": 4, "name": "Kelly & bankroll",                 "desc": "Optimal bet sizing, log-utility.", "prereqs": ["ev_betting"] },
    { "id": "time_value",         "family": "finance",     "tier": 3, "name": "Discounting & time value",         "desc": "Present value, interest, compounding.", "prereqs": ["fractions_decimals"] },

    { "id": "invariants",         "family": "teasers",     "tier": 3, "name": "Invariants & monovariants",        "desc": "Find a quantity that never changes / moves one way.", "prereqs": ["basic_counting"] },
    { "id": "parity",             "family": "teasers",     "tier": 2, "name": "Parity & coloring",                "desc": "Odd/even and coloring arguments.", "prereqs": ["basic_counting"] },
    { "id": "extremal",           "family": "teasers",     "tier": 3, "name": "Extremal principle",               "desc": "Consider the largest/smallest element.", "prereqs": ["basic_counting"] },
    { "id": "work_backwards",     "family": "teasers",     "tier": 2, "name": "Working backwards",                "desc": "Reason from the end state to the start.", "prereqs": [] },
    { "id": "casework",          "family": "teasers",     "tier": 1, "name": "Casework & exhaustion",            "desc": "Systematic case splitting.", "prereqs": [] },
    { "id": "symmetry_teaser",    "family": "teasers",     "tier": 2, "name": "Symmetry (puzzles)",               "desc": "Symmetry/strategy-stealing in puzzles & games.", "prereqs": [] },
    { "id": "construction",       "family": "teasers",     "tier": 3, "name": "Construction & algorithms",         "desc": "Build an explicit procedure/strategy.", "prereqs": ["casework"] },

    { "id": "backward_induction", "family": "games",       "tier": 4, "name": "Backward induction",               "desc": "Solve sequential games from the end.", "prereqs": ["work_backwards"] },
    { "id": "zero_sum",           "family": "games",       "tier": 4, "name": "Zero-sum & minimax",               "desc": "Optimal play in adversarial games.", "prereqs": ["casework"] },
    { "id": "make_market",        "family": "games",       "tier": 4, "name": "Making markets",                   "desc": "Quote bid/ask, manage edge & spread.", "prereqs": ["ev_betting"] },
    { "id": "adverse_selection",  "family": "games",       "tier": 5, "name": "Adverse selection & info",         "desc": "Update on the fact that someone trades with you.", "prereqs": ["make_market", "bayes"] },
    { "id": "optimal_strategy",   "family": "games",       "tier": 4, "name": "Optimal stopping / strategy",      "desc": "When to stop/act to maximize payoff (secretary, etc.).", "prereqs": ["cond_expectation"] },

    { "id": "algebra_manipulation","family": "puremath",   "tier": 2, "name": "Algebraic manipulation",           "desc": "Identities, factoring, solving equations cleverly.", "prereqs": [] },
    { "id": "inequalities",       "family": "puremath",    "tier": 3, "name": "Inequalities (AM–GM, Cauchy–Schwarz)","desc": "Classic inequality techniques and bounds.", "prereqs": ["algebra_manipulation"] },
    { "id": "linear_algebra",     "family": "puremath",    "tier": 3, "name": "Linear algebra",                   "desc": "Vectors, matrices, inner products, eigenvalues.", "prereqs": ["algebra_manipulation"] },
    { "id": "number_theory",      "family": "puremath",    "tier": 3, "name": "Number theory & divisibility",     "desc": "Primes, modular arithmetic, divisibility.", "prereqs": ["algebra_manipulation"] },
    { "id": "sequences_series",   "family": "puremath",    "tier": 3, "name": "Sequences, series & limits",       "desc": "Arithmetic/geometric series, growth, limits.", "prereqs": ["algebra_manipulation"] },
    { "id": "calculus",           "family": "puremath",    "tier": 2, "name": "Calculus (derivatives & integrals)","desc": "Differentiation, integration, related rates, optimization.", "prereqs": ["algebra_manipulation"] },
    { "id": "lln_clt",            "family": "stats",       "tier": 4, "name": "LLN & CLT",                        "desc": "Laws of large numbers, central limit theorem.", "prereqs": ["normal", "variance_props"] }
  ]
}
